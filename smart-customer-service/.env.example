# Security Configuration (REQUIRED)
# JWT Secret Key - 必须设置，至少32字符
# 生成命令: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key-must-be-at-least-32-characters-long

# Service API Keys - 必须设置，逗号分隔，每个key至少16字符
# 示例: sk-prod-xxxxxxxxxxxxxxxx,sk-dev-yyyyyyyyyyyyyyyy
SERVICE_API_KEYS=your-service-api-key-min-16-chars

# Langfuse Configuration
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# OpenAI API Key (for LLM calls)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Environment Settings
ENVIRONMENT=development
RELEASE_VERSION=v1.0.0

# Optional: Custom settings
LOG_LEVEL=INFO
ENABLE_TRACING=true

# External API Configuration (for Tool Calling)
TICKET_API_URL=https://api.example.com/tickets
TICKET_API_KEY=your_ticket_api_key
PRODUCT_API_URL=https://api.example.com/products
PRODUCT_API_KEY=your_product_api_key
ACCOUNT_API_URL=https://api.example.com/accounts
ACCOUNT_API_KEY=your_account_api_key

# Human Agent Notification (e.g., webhook URL)
HUMAN_AGENT_WEBHOOK_URL=https://hooks.example.com/human-agent
HUMAN_AGENT_WEBHOOK_SECRET=your_webhook_secret

# Sentiment Analysis Service
SENTIMENT_API_URL=https://api.example.com/sentiment
SENTIMENT_API_KEY=your_sentiment_api_key
# Alternative: Use OpenAI for sentiment analysis (uses OPENAI_API_KEY if set)
SENTIMENT_USE_OPENAI=false

# RAG Knowledge Base Configuration
KNOWLEDGE_BASE_DIR=./docs
# Optional: Load documents from remote URLs (comma-separated)
# KNOWLEDGE_BASE_URLS=https://docs.example.com/guide.md,https://docs.example.com/faq.md
